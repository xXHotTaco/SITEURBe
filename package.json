{
  "name": "siteurbe-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API para reportes de recepcion y mantenimiento de unidades.",
  "main": "src/server.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute siteurbe-db --local --file=./migrations/001_create_reception_reports_d1.sql",
    "db:migrate:remote": "wrangler d1 execute siteurbe-db --remote --file=./migrations/001_create_reception_reports_d1.sql",
    "typecheck": "node scripts/check-syntax.js"
  },
  "dependencies": {
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "wrangler": "^4.20.5"
  },
  "engines": {
    "node": ">=20"
  }
}
